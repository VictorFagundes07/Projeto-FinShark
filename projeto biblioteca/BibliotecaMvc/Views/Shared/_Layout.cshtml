<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Biblioteca</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark container">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Biblioteca</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Menu</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuários</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Livros" asp-action="Index">Livros</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Emprestimos" asp-action="Index">Empréstimos</a></li>
                    </ul>
                    <div class="d-flex gap-2 align-items-center">
                        @if (Context.Session.GetString("UsuarioNome") is string nome)
                        {
                            <span class="text-light small">@nome</span>
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Sair</a>
                        }
                        else
                        {
                            <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @if (TempData["Mensagem"] is string mensagem)
        {
            <div class="alert alert-success">@mensagem</div>
        }
        @if (TempData["Erro"] is string erro)
        {
            <div class="alert alert-danger">@erro</div>
        }
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
