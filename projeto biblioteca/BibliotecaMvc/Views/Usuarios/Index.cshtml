@model IEnumerable<Usuario>
@{
    ViewData["Title"] = "Usuários";
}

<section class="page-title"><h1>Usuários</h1><a class="btn btn-primary" asp-action="Create">Novo usuário</a></section>
<table class="table table-dark table-hover align-middle data-table">
    <thead><tr><th>Nome</th><th>E-mail</th><th>Nascimento</th><th>Idade</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.NomeCompleto</td>
            <td>@item.Email</td>
            <td>@item.DataNascimento.ToString("dd/MM/yyyy")</td>
            <td>@item.Idade</td>
            <td>@item.Status</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-info" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
    }
    </tbody>
</table>
