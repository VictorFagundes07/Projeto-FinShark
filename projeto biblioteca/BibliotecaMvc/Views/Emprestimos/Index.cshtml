@model IEnumerable<Emprestimo>
@{
    ViewData["Title"] = "Empréstimos";
}

<section class="page-title"><h1>Empréstimos</h1><a class="btn btn-primary" asp-action="Create">Registrar empréstimo</a></section>
<form class="filter-bar" method="get">
    <select name="usuarioId" asp-items="ViewBag.UsuarioId" class="form-select"><option value="">Todos os usuários</option></select>
    <button class="btn btn-outline-info">Consultar histórico</button>
</form>
<table class="table table-dark table-hover align-middle data-table">
    <thead><tr><th>Usuário</th><th>Livro</th><th>Empréstimo</th><th>Prevista</th><th>Real</th><th>Multa</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        var atrasado = item.Status == StatusEmprestimo.Emprestado && item.DataPrevistaDevolucao.Date < DateTime.Today;
        <tr>
            <td>@item.Usuario?.NomeCompleto</td>
            <td>@item.Livro?.Nome</td>
            <td>@item.DataEmprestimo.ToString("dd/MM/yyyy")</td>
            <td>@item.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</td>
            <td>@(item.DataRealDevolucao?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td>@item.Multa.ToString("C")</td>
            <td>@(atrasado ? "Atrasado" : item.Status)</td>
            <td class="text-end">
                @if (item.Status == StatusEmprestimo.Emprestado)
                {
                    <a class="btn btn-sm btn-warning" asp-action="Devolver" asp-route-id="@item.Id">Devolver</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
