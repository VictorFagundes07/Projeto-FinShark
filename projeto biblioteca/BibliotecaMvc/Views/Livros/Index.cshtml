@model IEnumerable<Livro>
@{
    ViewData["Title"] = "Livros";
}

<section class="page-title"><h1>Livros</h1><a class="btn btn-primary" asp-action="Create">Novo livro</a></section>
<form class="filter-bar" method="get">
    <input name="busca" value="@ViewBag.Busca" class="form-control" placeholder="Buscar por nome, autor ou categoria" />
    <label class="form-check">
        <input class="form-check-input" type="checkbox" name="somenteDisponiveis" value="true" @(ViewBag.SomenteDisponiveis == true ? "checked" : "") />
        <span class="form-check-label">Somente disponíveis</span>
    </label>
    <button class="btn btn-outline-info">Buscar</button>
</form>
<table class="table table-dark table-hover align-middle data-table">
    <thead><tr><th>Livro</th><th>Autor</th><th>Categoria</th><th>Faixa</th><th>Ano</th><th>Disponível</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nome</td><td>@item.Autor</td><td>@item.Categoria</td><td>@item.FaixaEtariaPermitida+</td><td>@item.AnoPublicacao</td><td>@item.QuantidadeEstoque</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-info" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
    }
    </tbody>
</table>
