@model Livro

<form method="post" class="form-card">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="Nome" class="form-label"></label><input asp-for="Nome" class="form-control" /><span asp-validation-for="Nome" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="Autor" class="form-label"></label><input asp-for="Autor" class="form-control" /><span asp-validation-for="Autor" class="text-danger"></span></div>
        <div class="col-md-3"><label asp-for="QuantidadeEstoque" class="form-label"></label><input asp-for="QuantidadeEstoque" class="form-control" min="0" /><span asp-validation-for="QuantidadeEstoque" class="text-danger"></span></div>
        <div class="col-md-3"><label asp-for="FaixaEtariaPermitida" class="form-label"></label><select asp-for="FaixaEtariaPermitida" class="form-select"><option value="0">Livre</option><option>10</option><option>12</option><option>14</option><option>16</option><option>18</option></select><span asp-validation-for="FaixaEtariaPermitida" class="text-danger"></span></div>
        <div class="col-md-3"><label asp-for="Categoria" class="form-label"></label><input asp-for="Categoria" class="form-control" /><span asp-validation-for="Categoria" class="text-danger"></span></div>
        <div class="col-md-3"><label asp-for="AnoPublicacao" class="form-label"></label><input asp-for="AnoPublicacao" class="form-control" /><span asp-validation-for="AnoPublicacao" class="text-danger"></span></div>
    </div>
    <div class="mt-4"><button class="btn btn-primary">Salvar</button> <a class="btn btn-secondary" asp-action="Index">Voltar</a></div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
